# Copiar a .env y completar los valores reales. NUNCA commitear el .env real.

# URL de conexión a PostgreSQL.
# Opciones recomendadas:
#   - Neon (https://neon.tech) — gratis, sin instalar nada
#   - Railway (https://railway.app) — gratis hasta cierto uso
#   - Postgres local (Postgres.app, Docker, scoop install postgresql)
DATABASE_URL=postgres://user:password@host:5432/dbname

# Secreto para firmar las cookies de sesión. Generar uno aleatorio largo:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=cambiame-por-un-string-aleatorio-largo

# Puerto del servidor HTTP. Railway lo setea automáticamente vía $PORT.
PORT=3000

# Modo: development | production
NODE_ENV=development
